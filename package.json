{
  "name": "simex-dashboard-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test",
    "predev": "node scripts/build-portable-data.mjs",
    "dev": "vite --host 0.0.0.0",
    "prebuild": "node scripts/build-portable-data.mjs",
    "build": "vite build",
    "build:cloudflare": "set SIMEX_EMBED_PORTABLE_DATA=0&& set VITE_SHOW_COMPATIBILITY_REPORTS=false&& node scripts/build-portable-data.mjs && vite build",
    "build:cloudflare:linux": "SIMEX_EMBED_PORTABLE_DATA=0 VITE_SHOW_COMPATIBILITY_REPORTS=false node scripts/build-portable-data.mjs && vite build",
    "build:flashdrive": "pnpm.cmd build",
    "migrate:chart-schema": "node scripts/migrate-chart-schema-v2.mjs",
    "package:flashdrive": "pnpm build && node scripts/package-flashdrive.mjs",
    "promote:bundle": "node scripts/promote-dashboard-bundle.mjs",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "echarts": "^5.6.0",
    "echarts-for-react": "^3.0.2",
    "papaparse": "^5.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.6.0",
    "vite": "^6.3.5"
  }
}
